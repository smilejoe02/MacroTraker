<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.AddFoodController"
      spacing="14"
      style="-fx-background-color: #eef4f8; -fx-padding: 25;">

    <children>

        <Label text="Add Food"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1f3349;" />

        <TextField fx:id="foodNameField"
                   promptText="Food Name" />

        <TextField fx:id="caloriesField"
                   promptText="Calories" />

        <TextField fx:id="proteinField"
                   promptText="Protein (g)" />

        <TextField fx:id="carbsField"
                   promptText="Carbs (g)" />

        <TextField fx:id="fatsField"
                   promptText="Fats (g)" />

        <ComboBox fx:id="mealTypeComboBox"
                  promptText="Select Meal Type" />

        <DatePicker fx:id="entryDatePicker" />

        <Label fx:id="messageLabel"
               text=""
               style="-fx-text-fill: #d62839; -fx-font-size: 13px;" />

        <Button text="Save Food"
                onAction="#handleSaveFood"
                style="-fx-background-color: #10c64a; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />

        <Button text="Back to Dashboard"
                onAction="#handleBackToDashboard"
                style="-fx-background-color: #dbe4ec; -fx-text-fill: #1f3349; -fx-font-size: 14px;" />

    </children>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
</VBox>