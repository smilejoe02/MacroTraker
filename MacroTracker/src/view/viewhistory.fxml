<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ViewHistoryController"
      spacing="12">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <TableView fx:id="historyTable" prefHeight="400">
        <columns>
            <TableColumn fx:id="foodNameColumn" text="Food Name" prefWidth="150" />
            <TableColumn fx:id="caloriesColumn" text="Calories" prefWidth="100" />
            <TableColumn fx:id="proteinColumn" text="Protein" prefWidth="100" />
            <TableColumn fx:id="carbsColumn" text="Carbs" prefWidth="100" />
            <TableColumn fx:id="fatColumn" text="Fat" prefWidth="100" />
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="120" />
        </columns>
    </TableView>

    <Button text="Back to Dashboard" onAction="#handleBackToDashboard" />
</VBox>